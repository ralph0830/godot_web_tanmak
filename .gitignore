# ============================================================
# Godot 4 프로젝트 .gitignore
# ============================================================

# Godot 에디터 캐시/임포트 데이터 (자동 생성, 추적 불필요)
.godot/
.godot/**

# 웹 빌드 산출물 (deploy.sh 로 자동 생성됨)
/web/*
!/web/.gitkeep

# 기타 플랫폼 빌드 산출물
/builds/
/export/
/android/
/ios/

# ============================================================
# 환경 변수 (실제 SSH/서버 정보 — 절대 커밋 금지)
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# OS / 에디터
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace

# 로그
*.log
deploy/*.log
