# ============================================================
# TANMAK 배포 환경 변수 샘플
# ------------------------------------------------------------
# 사용법:
#   1. 이 파일을 복사해 .env 를 만듭니다:  cp .env.example .env
#   2. 실제 서버 정보로 값을 채웁니다.
#   3. .env 는 .gitignore 로 추적 제외됩니다 (절대 커밋 금지).
#   4. deploy/deploy.sh 가 이 파일을 읽어 자동 배포합니다.
# ============================================================

# === 배포 대상 서버 (SSH) ===
DEPLOY_HOST=192.168.0.100              # 우분투 서버 IP (또는 도메인)
DEPLOY_PORT=22                         # SSH 포트
DEPLOY_USER=deploy                     # 배포용 계정 (WEB_ROOT 에 쓰기 권한 필요)
DEPLOY_SSH_KEY=~/.ssh/id_ed25519       # 권장: SSH 키 인증 경로
# 비밀번호 인증(권장하지 않음) — sshpass 필요:
# DEPLOY_SSH_PASSWORD=yourpassword

# === 웹 서버 (nginx) ===
WEB_PORT=2713                          # Nginx Proxy Manager 가 프록시할 로컬 포트
WEB_ROOT=/var/www/tanmak               # Godot 웹 빌드 정적 파일 경로
WEB_HOST=0.0.0.0                       # nginx listen 바인딩 (NPM 내부망이면 127.0.0.1 도 가능)

# === Git 저장소 ===
GIT_REPO_URL=https://github.com/ralph0830/godot_web_tanmak.git
GIT_BRANCH=main

# === Godot 웹 내보내기 ===
GODOT_BIN=godot                        # Godot 실행 파일 (PATH 에 있으면 godot, 아니면 전체 경로)
GODOT_EXPORT_PRESET=Web                # export_presets.cfg 의 프리셋 이름
GODOT_THREADS_ENABLED=false            # 웹 호환성: 스레드 OFF → SharedArrayBuffer 불필요
GODOT_COMPRESSION=brotli               # brotli(권장) | gzip
GODOT_EXPORT_OUTPUT=web/index.html     # 내보내기 산출물 진입점

# === 게임 메타 (선택, 빌드/문서에 주입 가능) ===
GAME_TITLE=TANMAK Shooter
GAME_VERSION=0.1.0
