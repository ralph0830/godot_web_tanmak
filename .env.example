# ============================================================
# TANMAK 배포 환경 변수 샘플
# ------------------------------------------------------------
# 사용법:
#   1. 이 파일을 복사해 .env 를 만듭니다:  cp .env.example .env
#   2. 실제 서버 정보로 값을 채웁니다.
#   3. .env 는 .gitignore 로 추적 제외됩니다 (절대 커밋 금지).
#   4. deploy/deploy.sh 가 이 파일을 읽어 자동 배포합니다.
# ============================================================

# === 배포 대상 서버 (SSH) ===
DEPLOY_HOST=ralphpark.com              # 우분투 서버 호스트/IP
DEPLOY_PORT=2202                       # SSH 포트
DEPLOY_USER=ralph                      # 배포용 계정 (WEB_ROOT 쓰기 권한 + sudo)
DEPLOY_SSH_KEY=                        # 빈 값 = 기본 키(~/.ssh/*) 또는 ssh-agent. 권장: 키 경로 명시

# === 웹 서비스 ===
DEPLOY_DOMAIN=tanmak.ralphpark.com     # NPM 역프록시 도메인 (헬스체크 대상, 비어있으면 호스트:포트 사용)
WEB_PORT=2713                          # nginx 리스닝 포트 (NPM 이 이 포트로 프록시)
WEB_ROOT=/home/ralph/work/web/tanmak   # Godot 웹 빌드 정적 파일 경로

# === Godot 웹 내보내기 ===
GODOT_BIN=godot                        # Godot 실행 파일 (PATH 에 있으면 godot, 아니면 전체 경로)
GODOT_EXPORT_PRESET=Web                # export_presets.cfg 의 프리셋 이름 (nothreads)
GODOT_EXPORT_OUTPUT=web/index.html     # 내보내기 산출물 진입점
